# Build Command:
# docker build -t bcollazo/catanatron-server:latest . -f Dockerfile.web
FROM python:3.12

WORKDIR /app

RUN pip install --upgrade pip

COPY . .
# Policy-debug API needs torch + gymnasium. Use CPU-only torch (much smaller than default CUDA
# builds) and --no-cache-dir to avoid filling the disk during docker build.
RUN pip install --no-cache-dir -e ".[web,gym]" \
    && pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

EXPOSE 5001

ENV FLASK_DEBUG=1
ENV FLASK_APP=catanatron.web/catanatron.web
ENV FLASK_RUN_HOST=0.0.0.0
ENV FLASK_RUN_PORT=5001

CMD flask run
